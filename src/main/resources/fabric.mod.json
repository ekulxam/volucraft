{
	"schemaVersion": 1,
	"id": "volucraft",
	"version": "${version}",
	"name": "Volucraft",
	"description": "3D Crafting",
	"authors": [
		"Survivalblock"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/volucraft",
		"sources": "https://github.com/ekulxam/volucraft",
        "issues": "https://github.com/ekulxam/volucraft/issues"
	},
	"license": "Apache-2.0",
	"icon": "assets/volucraft/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "survivalblock.volucraft.common.Volucraft"
		],
        "client": [
          "survivalblock.volucraft.client.VolucraftClient"
        ],
		"fabric-datagen": [
          "survivalblock.volucraft.client.datagen.VolucraftDataGenerator"
		],
        "modmenu": [
          "survivalblock.volucraft.client.compat.config.VolucraftModMenuCompat"
        ],
        "rrv": [
          "survivalblock.volucraft.common.compat.recipeviewer.VolucraftRRVCompat"
        ],
        "rrv_client": [
          "survivalblock.volucraft.client.compat.recipeviewer.VolucraftClientRRVCompat"
        ]
	},
	"mixins": [
		"volucraft.mixins.json"
	],
    "accessWidener": "volucraft.classtweaker",
	"depends": {
		"fabricloader": ">=0.19.0",
		"minecraft": "26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	},
    "custom": {
        "modmenu": {
          "links": {
              "modmenu.discord": "https://discord.gg/JE5bzhnwFV"
          }
        }
    }
}